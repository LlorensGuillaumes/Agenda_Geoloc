drizzle/migrations/meta/_journal.json.bak

# Local DB files (development)
*.db
*.db-journal
*.sqlite
*.sqlite3

# Turbo / cache
.turbo/
.cache/

# Testing
coverage/

# Temporary
tmp/
temp/

# Override global gitignore (user's D:\ProjectesGit\gitignore_global.txt
# excludes **/packages/* which conflicts with our monorepo structure)
!packages/
!packages/**
# Re-exclude node_modules, build artifacts, env files and DB inside packages
packages/*/node_modules/
packages/**/node_modules/
packages/*/dist/
packages/*/build/
packages/*/*.tsbuildinfo
packages/*/local.db
packages/*/local.db-journal
packages/**/.env
packages/**/.env.local
packages/**/.env.*.local
