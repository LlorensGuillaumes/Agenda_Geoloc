{
  "name": "agenda",
  "version": "0.0.1",
  "private": true,
  "description": "Agenda con alarmas temporales y geofencing + amigos",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @agenda/api",
    "dev:mobile": "npm start -w mobile",
    "start:api": "npm start -w @agenda/api",
    "db:generate": "npm run db:generate -w @agenda/db",
    "db:migrate": "npm run db:migrate -w @agenda/db",
    "db:studio": "npm run db:studio -w @agenda/db",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
