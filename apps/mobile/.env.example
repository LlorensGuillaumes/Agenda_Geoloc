# Endpoint del backend.
# Opciones:
# - localhost (Web / iOS Simulator):                        http://localhost:4000
# - Android emulator (alias del host):                      http://10.0.2.2:4000
# - Móvil físico vía LAN Wi-Fi (mismo router):              http://<IP-LAN>:4000
# - Móvil físico vía Tailscale (cualquier red):             http://<IP-TAILSCALE>:4000
# - API desplegada en Render (producción):                  https://<app>.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:4000
